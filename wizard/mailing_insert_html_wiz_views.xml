<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="view_mailing_insert_html_wizard_form" model="ir.ui.view">
        <field name="name">mailing.insert.html.wizard.form</field>
        <field name="model">mailing.insert.html.wizard</field>
        <field name="arch" type="xml">
            <form string="Insert HTML">
                <sheet>
                    <group>
                        <field name="html_content"
                               widget="text"
                               nolabel="1"
                               placeholder="Paste full HTML here (supports complete documents with &lt;html&gt;/&lt;body&gt;)."/>
                    </group>
                </sheet>

                <footer>
                    <button name="action_apply_html"
                            type="object"
                            string="Apply"
                            class="btn-primary"/>

                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_mailing_insert_html_wizard" model="ir.actions.act_window">
        <field name="name">Insert HTML</field>
        <field name="res_model">mailing.insert.html.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
